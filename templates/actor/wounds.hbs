<section
  class='tab wounds {{tab.cssClass}}'
  data-group='primary'
  data-tab='wounds'
>  
  <ol class="items-list wound-list">
    <li class="item flexrow items-header">
      <div class="item-name wound-name">{{localize "RAILERS.Item.Wound.FIELDS.wound"}}</div>
      <div class="wound-damage">{{localize "RAILERS.Item.Wound.FIELDS.damage"}}</div>
      <div class="wound-severity">{{localize "RAILERS.Item.Wound.FIELDS.severity"}}</div>
      <div class="item-controls wound-controls">
        {{#if @root.editable}}
          <a
            class="item-control item-create"
            title="{{localize 'RAILERS.dialogs.wound.addWound'}}"
            data-action="addWound"
            data-document-class="Item"
            data-type="wound"
          >
            <i class="fas fa-plus"></i>
            {{localize "DOCUMENT.New" type="wound"}}
          </a>
        {{/if}}
      </div>
    </li>
    {{#each wounds as |item id|}}
      <li class="item wound flexrow" data-item-id="{{item._id}}" data-drag="true" data-document-class="Item">
        <div class="item-name wounds-name">
          <div class="item-image">
          <a class="rollable" data-roll-type="item" data-action="roll">
              <img src="{{item.img}}"  width="24" height="24"/>
            </a>
          </div>
          <div>{{item.name}}</div>
        </div>
        <div class="wound-damage">{{item.system.damage}}</div>
        <div class="wound-severity">{{item.system.severity}}</div>
        <div class="wound-controls">
          <a class="wound-control wound-heal" title="{{localize 'RAILERS.Item.base.actions.heal'}}" data-action="woundHeal">
            <i class="fas fa-minus"></i>
          </a>
          <a class="item-control item-edit" title="{{localize 'DOCUMENT.Update' type='Wound'}}" data-action="viewDoc">
            <i class="fas fa-edit"></i>
          </a>
          {{#if @root.editable}}
            <a class="item-control item-delete" title="{{localize 'DOCUMENT.Delete' type='Wound'}}" data-action="deleteDoc">
              <i class="fas fa-trash"></i>
            </a>
          {{/if}}
        </div>
      </li>
    {{/each}}
  </ol>
</section>