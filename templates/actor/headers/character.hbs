<header class="sheet-head">
  <div class="header-top">
    <div class="header-identity">
        <img class="profile-img" src="{{actor.img}}" data-edit="img" data-action="editImage" title="{{actor.name}}" height="100" width="100"/>
        <div class="header-name-vitals">
            <div class="charname">
                <h1><input name="name" type="text" value="{{actor.name}}" placeholder="Name"/></h1>
            </div>
            <div class="header-vitals">
                <div class="resource flex-group-center">
                    <label class="resource-label">{{localize "RAILERS.Actor.base.FIELDS.hitpoints.value"}}</label>
                    <div class="resource-content flexrow flex-center flex-between">
                    <input type="number" value="{{system.hitpoints.value}}" readonly/>
                    <span> / </span>
                    <input type="number" name="system.hitpoints.max" value="{{system.hitpoints.max}}"/>
                    </div>
                </div>
                <div class="resource flex-group-center">
                    <label class="resource-label">{{localize "RAILERS.Actor.base.FIELDS.wounds.value"}}</label>
                    <div class="resource-content flexrow flex-center flex-between">
                    <input type="number" value="{{system.wounds.value}}" readonly/>
                    <span> / </span>
                    <input type="number" value="{{system.wounds.max}}" readonly/>
                    </div>
                </div>

                <div class="resource flex-group-center">
                    <label class="resource-label">{{localize "RAILERS.Actor.base.FIELDS.nerve.value"}}</label>
                    <div class="resource-content flexrow flex-center flex-between">
                    <input type="number" name="system.nerve.value" value="{{system.nerve.value}}"/>
                    <span> / </span>
                    <input type="number" name="system.nerve.max" value="{{system.nerve.max}}"/>
                    </div>
                </div>
                <div class="hp-button">
                    {{#if showHpRollButton}}
                    <button type="button" data-roll-type="hp" data-action="roll" class="roll-hp">
                        {{localize "RAILERS.Actor.Character.actions.rollHPNerve"}}
                    </button>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>
  </div>

  <div class="header-secondary">
    <div class="resource flex-group-center">
        <label class="resource-label">{{localize "RAILERS.Actor.base.FIELDS.corruption"}}</label>
        <div class="resource-content flexrow flex-center flex-between">
            <input type="number" name="system.corruption" value="{{system.corruption}}"/>
        </div>
    </div>

    <div class="resource flex-group-center">
        <label class="resource-label">{{localize "RAILERS.Actor.base.FIELDS.thermalThreshold"}}</label>
        <div class="resource-content flexrow flex-center flex-between">
            <input type="number" value="{{system.thermalThreshold}}" readonly/>
        </div>
    </div>

    <div class="resource flex-group-center">
        <label class="resource-label">{{localize "RAILERS.Actor.base.FIELDS.initiativePool"}}</label>
        <div class="resource-content flexrow flex-center flex-between">
            <input type="number" value="{{system.initiativePool}}" readonly/>
        </div>
    </div>

    <div class="resource flex-group-center">
      <label class="resource-label rollable" data-roll-type="defense" data-action="roll">{{localize "RAILERS.Actor.base.FIELDS.defensePool"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" value="{{system.defensePool}}" readonly/>
      </div>
    </div>

    <div class="resource flex-group-center">
      <label class="resource-label">{{localize "RAILERS.Actor.Character.FIELDS.xp"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" name="system.xp" value="{{system.xp}}"/>
      </div>
    </div>
  </div>
</header>