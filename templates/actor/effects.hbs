<section
  class='tab effects {{tab.cssClass}}'
  data-group='primary'
  data-tab='effects'
>  {{#if (eq actor.type "demon")}}
  {{!-- Condition List --}}
  <ol class="items-list conditions-list">
    <li class="condition item flexrow items-header">
      <div class="item-name textcenter">{{localize "RAILERS.Name"}}</div>
      <div class="item-description condition-description textcenter">{{localize "RAILERS.Description"}}</div>
      <div class="item-controls">
        <a class="item-control item-create" title="{{localize 'RAILERS.AddCondition'}}" data-type="condition"><i class="fas fa-plus"></i>{{localize "RAILERS.AddCondition"}}</a>
      </div>
    </li>
    {{#each items as |item id|}}
      {{#if (eq item.type "condition")}}
      <li class="condition item flexrow" data-item-id="{{item._id}}">
        <div class="item-name">
          <div class="item-image">
            <a class="rollable" data-roll-type="item"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></a>
          </div>
          <h4>{{item.name}}</h4>
        </div>
        <div class="item-description condition-description textcenter">{{{item.system.description}}}</div>
        <div class="item-controls">
          <a class="item-control item-edit" title="{{localize 'RAILERS.EditCondition'}}"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="{{localize 'RAILERS.DeleteCondition'}}"><i class="fas fa-trash"></i></a>
        </div>
      </li>
      {{/if}}
    {{/each}}
  </ol>

  {{else}}

  {{!-- Condition List --}}
  <ol class="items-list conditions-list">
    <li class="condition item flexrow items-header">
      <div class="item-name textcenter">{{localize "RAILERS.Name"}}</div>
      <div class="item-description condition-description textcenter">{{localize "RAILERS.Description"}}</div>
      <div class="item-controls">
        <a class="item-control item-create" title="{{localize 'RAILERS.AddCondition'}}" data-type="condition"><i class="fas fa-plus"></i>{{localize "RAILERS.AddCondition"}}</a>
      </div>
    </li>
    {{#each items as |item id|}}
      {{#if (eq item.type "condition")}}
      <li class="condition item flexrow" data-item-id="{{item._id}}">
        <div class="item-name">
          <div class="item-image">
            <a class="rollable" data-roll-type="item"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></a>
          </div>
          <h4>{{item.name}}</h4>
        </div>
        <div class="item-description condition-description textcenter">{{{item.system.description}}}</div>
        <div class="item-controls">
          <a class="item-control item-edit" title="{{localize 'RAILERS.EditCondition'}}"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="{{localize 'RAILERS.DeleteCondition'}}"><i class="fas fa-trash"></i></a>
        </div>
      </li>
      {{/if}}
    {{/each}}
  </ol>

  {{!-- Mutation List --}}
  <ol class="items-list mutations-list">
    <li class="mutation item flexrow items-header">
      <div class="item-name textcenter">{{localize "RAILERS.Name"}}</div>
      <div class="item-description mutation-description">{{localize "RAILERS.Description"}}</div>
      <div class="item-controls">
        <a class="item-control item-create" title="{{localize 'RAILERS.AddMutation'}}" data-type="mutation"><i class="fas fa-plus"></i>{{localize "RAILERS.AddMutation"}}</a>
      </div>
    </li>
    {{#each items as |item id|}}
      {{#if (eq item.type "mutation")}}
      <li class="mutation item flexrow" data-item-id="{{item._id}}">
        <div class="item-name">
          <div class="item-image">
            <a class="rollable" data-roll-type="item"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></a>
          </div>
          <h4>{{item.name}}</h4>
        </div>
        <div class="item-description mutation-description">{{{item.system.description}}}</div>
        <div class="item-controls">
          <a class="item-control item-edit" title="{{localize 'RAILERS.EditMutation'}}"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="{{localize 'RAILERS.DeleteMutation'}}"><i class="fas fa-trash"></i></a>
        </div>
      </li>
      {{/if}}
    {{/each}}
  </ol>
  {{/if}}
</section>
