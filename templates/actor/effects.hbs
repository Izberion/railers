<section 
  class='tab effects {{tab.cssClass}}' 
  data-group='primary' 
  data-tab='effects'
>

  <ol class='items-list'>
    {{#each effects as |section sid|}}
      <li class='items-header' data-effect-type='{{section.type}}'>
        <label class='item-name effect-name'>
          {{localize section.label}}
        </label>
        <div class='effect-source'>
          {{localize 'RAILERS.Effect.Source'}}
        </div>
        <div class='effect-duration'>
          {{localize 'RAILERS.Effect.Duration'}}
        </div>
        <div class='item-controls'>
          <a
            class='item-create'
            data-action='createDoc'
            data-document-class='ActiveEffect'
            {{#if (eq section.type "inactive")}}
              data-disabled="true"
            {{else if (eq section.type "temporary")}}
              data-duration.rounds="1"
            {{/if}}
            title='{{localize "DOCUMENT.Create" type='Effect'}}'
          >
            <i class='fas fa-plus'></i>
          </a>
        </div>
      </li>
      <ol class='item-list'>
        {{#each section.effects as |effect|}}
          <li
            class='item'
            data-effect-id='{{effect.id}}'
            data-parent-id='{{effect.parent.id}}'
            data-drag="true"
          >
            <div class='item-name'>
              <img class='item-image' src='{{effect.img}}' />
              <div>{{effect.name}}</div>
            </div>
            <div class='effect-source'>
              {{effect.sourceName}}
            </div>
            <div class='effect-duration'>
              {{effect.duration.label}}
            </div>
            <div class='item-controls'>
              <a
                class='effect-toggle'
                data-action='toggleEffect'
                title='{{localize "RAILERS.Effect.Toggle"}}'
              >
                <i class='fas {{#if effect.disabled}}fa-check{{else}}fa-times{{/if}}'></i>
              </a>
              <a
                class='item-edit'
                data-action='viewDoc'
                data-document-class='ActiveEffect'
                title='{{localize "DOCUMENT.Update" type='Effect'}}'
              >
                <i class='fas fa-edit'></i>
              </a>
              <a
                class='item-delete'
                data-action='deleteDoc'
                data-document-class='ActiveEffect'
                title='{{localize "DOCUMENT.Delete" type='Effect'}}'
              >
                <i class='fas fa-trash'></i>
              </a>
            </div>
          </li>
        {{/each}}
      </ol>
    {{/each}}
  </ol>
</section>