<header class="sheet-head">
  <div class="header-fields">
    <div class="charinfo">
      <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="100" width="100"/>
      <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" placeholder="Name"/></h1>
    </div>

    {{#ifOr (eq actor.type "character") (eq actor.type "npc") (eq actor.type "demon")}}
    {{!-- HP --}}
    <div class="health">
      <div class="resource flex-group-center">
        <label for="system.hitpoints.value" class="resource-label">{{localize "RAILERS.Actor.base.FIELDS.hitpoints.value"}}</label>
        <div class="resource-content flexrow flex-center flex-between">
          <input type="number" name="system.hitpoints.value" value="{{system.hitpoints.value}}" data-dtype="Number" readonly/>
          <span> / </span>
          <input type="number" name="system.hitpoints.max" value="{{system.hitpoints.max}}" data-dtype="Number"/>
        </div>
        {{#if (eq actor.type "demon")}}
          <button type="button" class="roll-hp">{{localize "RAILERS.Actor.Demon.FIELDS.actions.rollHP"}}</button>
        {{/if}}
      </div>

    {{!-- Wounds --}}
      <div class="resource flex-group-center">
        <label for="system.wounds.value" class="resource-label">{{localize "RAILERS.Actor.base.FIELDS.wounds.value"}}</label>
        <div class="resource-content flexrow flex-center flex-between">
          <input type="number" name="system.wounds.value" value="{{system.wounds.value}}" data-dtype="Number" readonly/>
          <span> / </span>
          <input type="number" name="system.wounds.max" value="{{system.wounds.max}}" data-dtype="Number" readonly/>
        </div>
      </div>
    {{/ifOr}}

    {{#ifOr (eq actor.type "character") (eq actor.type "npc")}}
    {{!-- Nerve --}}
      <div class="resource flex-group-center">
        <label for="system.nerve.value" class="resource-label">{{localize "RAILERS.Actor.base.FIELDS.nerve.value"}}</label>
        <div class="resource-content flexrow flex-center flex-between">
          <input type="number" name="system.nerve.value" value="{{system.nerve.value}}" data-dtype="Number"/>
          <span> / </span>
          <input type="number" name="system.nerve.max" value="{{system.nerve.max}}" data-dtype="Number"/>
        </div>
      </div>
    </div>

    {{!-- Corruption --}}
    <div class="corruption">
      <div class="resource flex-group-center">
        <label for="system.corruption.value" class="resource-label">{{localize "RAILERS.Actor.base.FIELDS.corruption"}}</label>
        <div class="resource-content flexrow flex-center flex-between">
          <input type="number" name="system.corruption" value="{{system.corruption}}" data-dtype="Number"/>
        </div>
      </div>
    </div>

    {{!-- Thermal Threshold --}}
    <div class="thermal-threshold">
      <div class="resource flex-group-center">
        <label class="resource-label">{{localize "RAILERS.Actor.base.FIELDS.thermalThreshold"}}</label>
        <input type="number" name="system.thermalThreshold" value="{{system.thermalThreshold}}" data-dtype="Number" readonly/>
      </div>
    </div>

    {{!-- Initiative Pool --}}
    <div class="combat-pools">
      <div class="resource flex-group-center">
        <label class="resource-label">{{localize "RAILERS.Actor.base.FIELDS.initiativePool"}}</label>
        <input type="number" name="system.initiativePool" value="{{system.initiativePool}}" data-dtype="Number" readonly/>
      </div>

    {{!-- Defense Pool --}}
      <div class="resource flex-group-center">
        <label class="resource-label rollable" data-roll="(@defensePool)d8x8cs>=5df1">{{localize "RAILERS.Actor.base.FIELDS.defensePool"}}</label>
        <input type="number" name="system.defensePool" value="{{system.defensePool}}" data-dtype="Number" readonly/>
      </div>
    </div>
    {{/ifOr}}
  </div>

  {{!-- XP --}}
  {{#if (eq actor.type "character")}}
  <div class="xp">
    <div class="resource flex-group-center">
      <label class="resource-label">{{localize "RAILERS.Actor.Character.FIELDS.xp"}}</label>
      <input type="number" name="system.xp" value="{{system.xp}}" data-dtype="Number"/>
    </div>
  </div>
  {{/if}}

  {{#if (eq actor.type "demon")}}
  {{!-- Attributes --}}
  <div class="demon-attributes">
    <div class="resource flex-group-center">
      <label for="system.attributes.strength" class="resource-label flex-group-center roll" data-npcpool="{{system.attributes.strength}}">{{localize "RAILERS.Attributes.Strength"}}</label>
      <input type="number" name="system.attributes.strength" value="{{system.attributes.strength}}" data-dtype="Number"/>
    </div>

    <div class="resource flex-group-center">
      <label for="system.attributes.agility" class="resource-label flex-group-center roll" data-npcpool="{{system.attributes.agility}}">{{localize "RAILERS.Attributes.Agility"}}</label>
      <input type="number" name="system.attributes.agility" value="{{system.attributes.agility}}" data-dtype="Number"/>
    </div>

    <div class="resource flex-group-center">
      <label for="system.attributes.intellect" class="resource-label flex-group-center roll" data-npcpool="{{system.attributes.intellect}}">{{localize "RAILERS.Attributes.Intellect"}}</label>
      <input type="number" name="system.attributes.intellect" value="{{system.attributes.intellect}}" data-dtype="Number"/>
    </div>

    <div class="resource flex-group-center">
      <label for="system.attributes.endurance" class="resource-label flex-group-center roll" data-npcpool="{{system.attributes.endurance}}">{{localize "RAILERS.Attributes.Endurance"}}</label>
      <input type="number" name="system.attributes.endurance" value="{{system.attributes.endurance}}" data-dtype="Number"/>
    </div>

    <div class="resource flex-group-center">
      <label for="system.attributes.fear" class="resource-label flex-group-center">{{localize "RAILERS.Actor.base.FIELDS.fear"}}</label>
      <input type="number" name="system.attributes.fear" value="{{system.attributes.fear}}" data-dtype="Number"/>
    </div>

    <div class="resource flex-group-center">
      <label for="system.attributes.attack" class="resource-label flex-group-center">{{localize "RAILERS.Attributes.Attack"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" name="system.attributes.attack.damage" value="{{system.attributes.attack.damage}}" data-dtype="Number"/>
        <span> / W </span>
        <input type="number" name="system.attributes.attack.severity" value="{{system.attributes.attack.severity}}" data-dtype="Number"/>
      </div>
    </div>
  </div>
  {{/if}}

  {{!-- Train-specific fields --}}
  {{#if (eq actor.type "train")}}
  <div class="train-attributes">
    <div class="resource flex-group-center">
      <label for="system.armor" class="resource-label">{{localize "RAILERS.Actor.Train.FIELDS.armor"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" name="system.armor" value="{{system.armor}}" data-dtype="Number"/>
      </div>
    </div>

    <div class="resource flex-group-center">
      <label for="system.speed" class="resource-label">{{localize "RAILERS.Actor.Train.FIELDS.maxSpeed"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" name="system.speed" value="{{system.speed}}" data-dtype="Number"/>
      </div>
    </div>

    <div class="resource flex-group-center">
      <label for="system.power.value" class="resource-label">{{localize "RAILERS.Actor.Train.FIELDS.power.label"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" name="system.power.value" value="{{system.power.value}}" data-dtype="Number"/>
        <span> / </span>
        <input type="number" name="system.power.max" value="{{system.power.max}}" data-dtype="Number"/>
      </div>
    </div>

    <div class="resource flex-group-center">
      <label for="system.weight.value" class="resource-label">{{localize "RAILERS.Actor.Train.FIELDS.weight.label"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" name="system.weight.value" value="{{system.weight.value}}" data-dtype="Number"/>
        <span> / </span>
        <input type="number" name="system.weight.max" value="{{system.weight.max}}" data-dtype="Number"/>
      </div>
    </div>

    <div class="resource flex-group-center">
      <label for="system.fuel.value" class="resource-label">{{localize "RAILERS.Actor.Train.FIELDS.fuel.label"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" name="system.fuel.value" value="{{system.fuel.value}}" data-dtype="Number"/>
        <span> / </span>
        <input type="number" name="system.fuel.max" value="{{system.fuel.max}}" data-dtype="Number"/>
      </div>
    </div>

    <div class="resource flex-group-center">
      <label for="system.crew" class="resource-label">{{localize "RAILERS.Actor.Train.FIELDS.crew"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" name="system.crew" value="{{system.crew}}" data-dtype="Number"/>
      </div>
    </div>

    <div class="resource flex-group-center">
      <label for="system.passengers" class="resource-label">{{localize "RAILERS.Actor.Train.FIELDS.passengers"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" name="system.passengers" value="{{system.passengers}}" data-dtype="Number"/>
      </div>
    </div>

    <div class="resource flex-group-center">
      <label for="system.rations.value" class="resource-label">{{localize "RAILERS.Actor.Train.FIELDS.rations.value"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" name="system.rations.value" value="{{system.rations.value}}" data-dtype="Number"/>
        <span> / </span>
        <input type="number" name="system.rations.max" value="{{system.rations.max}}" data-dtype="Number"/>
      </div>
    </div>
  </div>
  {{/if}}

  {{#if (eq actor.type "npc")}}
  <div class="npc-attributes">
    <div class="resources grid grid-3col">
      <div class="resource flex-group-center">
        <label for="system.primary" class="resource-label roll" data-npcpool="{{system.primary}}">{{localize "RAILERS.Attributes.Primary"}}</label>
        <input type="number" name="system.primary" value="{{system.primary}}" data-dtype="Number"/>
      </div>
      <div class="resource flex-group-center">
        <label for="system.secondary" class="resource-label roll" data-npcpool="{{system.secondary}}">{{localize "RAILERS.Attributes.Secondary"}}</label>
        <input type="number" name="system.secondary" value="{{system.secondary}}" data-dtype="Number" readonly/>
      </div>
      <div class="resource flex-group-center">
        <label class="resource-label roll" data-npcpool="0">{{localize "RAILERS.Attributes.Unskilled"}}</label>
      </div>
    </div>
  </div>
  {{/if}}

  {{#if (eq actor.type "demon")}}
  <div class="demon-tags">
    <input type="text" name="system.tags" value="{{system.tags}}" data-dtype="String" placeholder="Tags"/>
  </div>
  {{/if}}

  {{#if (eq actor.type "train")}}
  <div class="train-select">
    <select name="system.locomotive">
      {{selectOptions locomotiveOptions selected=system.locomotive localize=true}}
    </select>
  </div>
  {{/if}}
</header>