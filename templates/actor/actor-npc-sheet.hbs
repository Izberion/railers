<form class="{{cssClass}} {{actor.type}}" autocomplete="off">

  {{!-- Sheet Header --}}
  <header class="sheet-head">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="100" width="100"/>
    <div class="header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" placeholder="Name"/></h1>
      <div class="resources grid grid-3col">
        <div class="resource flex-group-center">
          <label for="system.primary" class="resource-label roll" data-npcpool="{{system.primary}}">{{localize "RAILERS.Primary"}}</label>
          <input type="number" name="system.primary" value="{{system.primary}}" data-dtype="Number"/>
        </div>
        <div class="resource flex-group-center">
          <label for="system.secondary" class="resource-label roll" data-npcpool="{{system.secondary}}">{{localize "RAILERS.Secondary"}}</label>
          <input type="number" name="system.secondary" value="{{system.secondary}}" data-dtype="Number" readonly/>
        </div>
        <div class="resource flex-group-center">
          <label class="resource-label roll" data-npcpool="0">{{localize "RAILERS.Tertiary"}}</label>
        </div>
      </div>
    </div>
  </header>

  {{!-- Sheet Sidebar --}}
  <aside class="sheet-sidebar">

    {{!-- HP --}}
    <div class="resource flex-group-center">
      <label for="system.hitpoints.value" class="resource-label">{{localize "RAILERS.Hitpoints"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" name="system.hitpoints.value" value="{{system.hitpoints.value}}" data-dtype="Number" readonly/>
        <span> / </span>
        <input type="number" name="system.hitpoints.max" value="{{system.hitpoints.max}}" data-dtype="Number"/>
      </div>
    </div>

    {{!-- Nerve --}}
    <div class="resource flex-group-center">
      <label for="system.nerve.value" class="resource-label">{{localize "RAILERS.Nerve"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" name="system.nerve.value" value="{{system.nerve.value}}" data-dtype="Number"/>
        <span> / </span>
        <input type="number" name="system.nerve.max" value="{{system.nerve.max}}" data-dtype="Number"/>
      </div>
    </div>

    {{!-- Wounds --}}
    <div class="resource flex-group-center">
      <label for="system.wounds.value" class="resource-label">{{localize "RAILERS.Wounds"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <input type="number" name="system.wounds.value" value="{{system.wounds.value}}" data-dtype="Number" readonly/>
        <span> / </span>
        <input type="number" name="system.wounds.max" value="{{system.wounds.max}}" data-dtype="Number" readonly/>
      </div>
    </div>

    {{!-- Corruption --}}
    <div class="resource flex-group-center">
      <label for="system.power.value" class="resource-label">{{localize "RAILERS.Corruption"}}</label>
      <input type="number" name="system.corruption.value" value="{{system.corruption.value}}" data-dtype="Number"/>
    </div>

    {{!-- Thermal Threshold --}}
    <div class="resource flex-group-center">
      <label class="resource-label">{{localize "RAILERS.ThermalThreshold"}}</label>
      <input type="number" name="system.thermalThreshold" value="{{system.thermalThreshold}}" data-dtype="Number" readonly/>
    </div>

    {{!-- Initiative Pool --}}
    <div class="resource flex-group-center">
      <label class="resource-label">{{localize "RAILERS.InitiativePool"}}</label>
      <input type="number" name="system.initiativePool" value="{{system.initiativePool}}" data-dtype="Number" readonly/>
    </div>

    {{!-- Defense Pool --}}
    <div class="resource flex-group-center">
      <label class="resource-label rollable" data-roll="(@defensePool)d8x8cs>=5df1">{{localize "RAILERS.DefensePool"}}</label>
      <input type="number" name="system.defensePool" value="{{system.defensePool}}" data-dtype="Number" readonly/>
    </div>
      
  </aside>

  {{!-- Sheet Tab Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    {{!-- Default tab is specified in actor-sheet.mjs --}}
    <a class="item" data-tab="gear">{{localize "RAILERS.Gear"}}</a>
    <a class="item" data-tab="wounds">{{localize "RAILERS.Wounds"}}</a>
    <a class="item" data-tab="effects">{{localize "RAILERS.Effects"}}</a>
    <a class="item" data-tab="notes">{{localize "RAILERS.Notes"}}</a>
  </nav>

  {{!-- Sheet Body --}}
  <section class="sheet-body">

    {{!-- Gear Tab --}}
    <div class="tab gear" data-group="primary" data-tab="gear">
      {{> "systems/railers/templates/actor/parts/actor-gear.hbs"}}
    </div>

    {{!-- Wounds Tab --}}
    <div class="tab wounds" data-group="primary" data-tab="wounds">
      {{> "systems/railers/templates/actor/parts/actor-wounds.hbs"}}
    </div>

    {{!-- Effects Tab --}}
    <div class="tab effects" data-group="primary" data-tab="effects">
      {{> "systems/railers/templates/actor/parts/actor-effects.hbs"}}
    </div>

    {{!-- Notes Tab --}}
    <div class="tab notes" data-group="primary" data-tab="notes">
      {{!-- If you want TinyMCE editors to output inline rolls when rendered, you need to pass the actor's roll data to the rollData property. --}}
      {{editor system.notes target="system.notes" rollData=rollData button=true owner=owner editable=editable}}
    </div>
    
  </section>
</form>

