<section
  class='tab cargo {{tab.cssClass}}'
  data-group='primary'
  data-tab='cargo'
>  {{!-- Item List --}}
  <ol class="items-list">
    <li class="item flexrow items-header">
      <div class="item-name">{{localize "RAILERS.Item.base.FIELDS.name"}}</div>
      <div class="item-armor">{{localize "RAILERS.Item.Cargo.FIELDS.purchasePrice"}}</div>
      <div class="item-weight">{{localize "RAILERS.Item.Cargo.FIELDS.weight"}}</div>
      <div class="item-controls">
        {{#if @root.editable}}
          <a
            class="item-control item-create"
            title="{{localize 'DOCUMENT.Create' type='Cargo'}}"
            data-action="createDoc"
            data-document-class="Item"
            data-type="cargo"
          >
            <i class="fas fa-plus"></i>
            {{localize "DOCUMENT.New" type="cargo"}}
          </a>
        {{/if}}
      </div>
    </li>
    {{#each cargo as |item id|}}
      <li class="item flexrow" data-item-id="{{item._id}}" data-drag="true" data-document-class="Item">
        <div class="item-name">
          <div class="item-image">
            <a class="rollable" data-roll-type="item" data-action="roll">
              <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
            </a>
          </div>
          <h4>{{item.name}}</h4>
        </div>
        <div class="item-price textcenter">{{item.system.price}}</div>
        <div class="item-weight textcenter">{{item.system.weight}}</div>
        <div class="item-controls">
          <a class="item-control item-edit" title="{{localize 'DOCUMENT.Update' type='Cargo'}}" data-action="viewDoc">
            <i class="fas fa-edit"></i>
          </a>
          {{#if @root.editable}}
            <a class="item-control item-delete" title="{{localize 'DOCUMENT.Delete' type='Cargo'}}" data-action="deleteDoc">
              <i class="fas fa-trash"></i>
            </a>
          {{/if}}
        </div>
      </li>
    {{/each}}
  </ol>
</section>