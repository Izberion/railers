<section
  class='tab cargo {{tab.cssClass}}'
  data-group='primary'
  data-tab='cargo'
>  {{!-- Item List --}}
  <div class="cargo-header">
    <div class="resource flex-group-center">
      <label class="resource-label">{{localize "RAILERS.Item.base.FIELDS.therms"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <a data-action="adjustTherms" data-mode="subtract" title="{{localize 'RAILERS.Actor.base.actions.spendTherms'}}">
          <i class="fas fa-minus"></i>
        </a>
        <input class="therms" type="number" name="system.therms" value="{{system.therms}}"/>
        <a data-action="adjustTherms" data-mode="add" title="{{localize 'RAILERS.Actor.base.actions.earnTherms'}}">
          <i class="fas fa-plus"></i>
        </a>
      </div>
    </div>
  </div>
  <ol class="items-list">
    <li class="items-header">
      <div class="item-name">{{localize "RAILERS.Item.Cargo.label"}}</div>
      <div class="item-price">{{localize "RAILERS.Item.Cargo.FIELDS.price"}}</div>
      <div class="item-weight">{{localize "RAILERS.Item.Cargo.FIELDS.weight"}}</div>
      <div class="item-controls">
        {{#if @root.editable}}
          <a
            class="item-create"
            title="{{localize 'DOCUMENT.Create' type='Cargo'}}"
            data-action="createDoc"
            data-document-class="Item"
            data-type="cargo"
          >
            <i class="fas fa-plus"></i>
          </a>
        {{/if}}
      </div>
    </li>
    {{#each cargo as |item id|}}
      <li class="item" data-item-id="{{item._id}}" data-drag="true" data-document-class="Item">
        <div class="item-name">
          <div class="item-image">
            <a class="rollable" data-roll-type="item" data-action="roll">
              <img src="{{item.img}}"  width="24" height="24"/>
            </a>
          </div>
          <div>{{item.name}}</div>
        </div>
        <div class="item-price textcenter">{{item.system.price}}</div>
        <div class="item-weight textcenter">{{item.system.weight}}</div>
        <div class="item-controls">
          <a class="item-edit" title="{{localize 'DOCUMENT.Update' type='Cargo'}}" data-action="viewDoc">
            <i class="fas fa-edit"></i>
          </a>
          {{#if @root.editable}}
            <a class="item-delete" title="{{localize 'DOCUMENT.Delete' type='Cargo'}}" data-action="deleteDoc">
              <i class="fas fa-trash"></i>
            </a>
          {{/if}}
        </div>
      </li>
    {{/each}}
  </ol>
</section>