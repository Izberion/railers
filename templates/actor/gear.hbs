<section
  class='tab gear {{tab.cssClass}}'
  data-group='primary'
  data-tab='gear'
>  <div class="grid grid-3col">
    <div class="resource flex-group-center">
      <label class="resource-label">{{localize "RAILERS.Therms"}}</label>
      <input type="number" name="system.therms" value="{{system.therms}}" data-dtype="Number"/>
    </div>
    <div class="resource flex-group-center grid-span-2">
      <label class="resource-label load-label">{{localize "RAILERS.Load"}}</label>
      <div class="resource-content flexrow flex-center flex-between">
        <label for="system.load.onHand.value">{{localize "RAILERS.OnHand"}}</label>
        <input type="number" name="system.load.onHand.value" value="{{system.load.onHand.value}}" data-dtype="Number" readonly/>
        <span> / </span>
        <input type="number" name="system.load.onHand.max" value="{{system.load.onHand.max}}" data-dtype="Number" readonly/>
      </div>
      <div class="resource-content flexrow flex-center flex-between">
        <label for="system.load.stowed.value">{{localize "RAILERS.Stowed"}}</label>
        <input type="number" name="system.load.stowed.value" value="{{system.load.stowed.value}}" data-dtype="Number" readonly/>
        <span> / </span>
        <input type="number" name="system.load.stowed.max" value="{{system.load.stowed.max}}" data-dtype="Number"/>
      </div>
    </div>
  </div>

  {{!-- Item List --}}
  <ol class="items-list">
    <li class="item flexrow items-header">
      <div class="item-name">{{localize "RAILERS.Name"}}</div>
      <div class="item-quantity">{{localize "RAILERS.Quantity"}}</div>
      <div class="item-load">{{localize "RAILERS.Load"}}</div>
      <div class="item-stowage">{{localize "RAILERS.Stowage"}}</div>
      <div class="item-controls">
        <a
          class='item-control item-create'
          title='{{localize "DOCUMENT.Create" type='Gear'}}'
          data-action='createDoc'
          data-document-class='Item'
          data-type='gear'
        >
          <i class='fas fa-plus'></i>
          {{localize 'DOCUMENT.New' type='gear'}}
        </a>
      </div>
    </li>
    {{#each gear as |item id|}}
      <li 
        class="item flexrow" 
        data-item-id="{{item._id}}"
        data-drag='true'
        data-document-class='Item'
      >
        <div class="item-name">
          <div class="item-image">
            <a class='rollable' data-roll-type='gear' data-action='roll'>
              <img src='{{item.img}}' title='{{item.name}}' width='24' height='24'/>
            </a>          
          </div>
          <div>{{item.name}}</div>
        </div>
        <div class="item-quantity">{{item.system.quantity}}</div>
        <div class="item-load">{{item.system.load}}</div>
        <div class="item-stowage">{{localize item.system.stowage}}</div>
        <div class="item-controls">
          <a
            class='item-control item-edit'
            title='{{localize "DOCUMENT.Update" type='Gear'}}'
            data-action='viewDoc'
          >
            <i class='fas fa-edit'></i>
          </a>
          <a
            class='item-control item-delete'
            title='{{localize "DOCUMENT.Delete" type='Gear'}}'
            data-action='deleteDoc'
          >
            <i class='fas fa-trash'></i>
          </a>
        </div>
      </li>
    {{/each}}
  </ol>

  {{!-- Weapon List --}}
  <ol class="weapons-list">
    <li class="weapon flexrow weapons-header items-header">
      <div class="weapon-name textcenter">{{localize "RAILERS.Name"}}</div>
      <div class="weapon-damage textcenter">{{localize "RAILERS.Damage"}}</div>
      <div class="weapon-attack textcenter">{{localize "RAILERS.Attack"}}</div>
      <div class="weapon-range textcenter">{{localize "RAILERS.Range"}}</div>
      <div class="weapon-reload textcenter">{{localize "RAILERS.Reload"}}</div>
      <div class="weapon-magazine textcenter">{{localize "RAILERS.Magazine"}}</div>
      <div class="weapon-load textcenter">{{localize "RAILERS.Load"}}</div>
      <div class="weapon-stowage textcenter">{{localize "RAILERS.Stowage"}}</div>
      <div class="weapon-controls">
        <a
          class='item-control item-create'
          title='{{localize "DOCUMENT.Create" type='Weapon'}}'
          data-action='createDoc'
          data-document-class='Item'
          data-type='weapon'
        >
          <i class='fas fa-plus'></i>
          {{localize 'DOCUMENT.New' type='weapon'}}
        </a>
      </div>
    </li>
    {{#each weapons as |item id|}}
      <li 
        class="item flexrow" 
        data-item-id="{{item._id}}"
        data-drag='true'
        data-document-class='Item'
      >
        <div class="weapon-name textcenter">
          <div class="weapon-image">
              <a class='rollable' data-roll-type='item' data-action='attackRoll'>
              <img src='{{item.img}}' title='{{item.name}}' width='24' height='24'/>
            </a>           
          </div>
          <div>{{item.name}}</div>
        </div>
        <div class="weapon-damage textcenter">{{item.system.damage}} {{localize "RAILERS.SlashWound"}} {{item.system.severity}}</div>
        <div class="weapon-attack textcenter">{{localize item.system.attack}}</div>
        <div class="weapon-range textcenter">{{localize item.system.range}}</div>
        <div class="weapon-reload textcenter">{{localize item.system.reload}}</div>
        <div class="weapon-magazine textcenter">{{item.system.magazine.value}} / {{item.system.magazine.max}}</div>
        <div class="weapon-load textcenter">{{item.system.load}}</div>
        <div class="weapon-stowage textcenter">{{localize item.system.stowage}}</div>
        <div class="weapon-controls">
          <a 
            class="weapon-control weapon-reload" 
            title="{{localize 'RAILERS.ReloadWeapon'}}"
            data-action="weaponReload"
          >
            <i class="fas fa-sync-alt"></i>
          </a>
          <a
            class='item-control item-edit'
            title='{{localize "DOCUMENT.Update" type='Weapon'}}'
            data-action='viewDoc'
          >
            <i class='fas fa-edit'></i>
          </a>
          <a
              class='item-control item-delete'
              title='{{localize "DOCUMENT.Delete" type='Weapon'}}'
              data-action='deleteDoc'
            >
              <i class='fas fa-trash'></i>
            </a>
        </div>
      </li>
    {{/each}}
  </ol>

  {{!-- Clothing List --}}
  <ol class="clothing-list">
    <li 
      class="item flexrow" 
      data-item-id="{{item._id}}"
      data-drag='true'
      data-document-class='Item'
    >
      <div class="clothing-name textcenter">{{localize "RAILERS.Name"}}</div>
      <div class="clothing-type textcenter">{{localize "RAILERS.Type"}}</div>
      <div class="clothing-protection textcenter">{{localize "RAILERS.Protection"}}</div>
      <div class="clothing-insulation textcenter">{{localize "RAILERS.Insulation"}}</div>
      <div class="clothing-load textcenter">{{localize "RAILERS.Load"}}</div>
      <div class="clothing-stowage textcenter">{{localize "RAILERS.Stowage"}}</div>
      <div class="clothing-controls">
        <a
          class='item-control item-create'
          title='{{localize "DOCUMENT.Create" type='Clothing'}}'
          data-action='createDoc'
          data-document-class='Item'
          data-type='clothing'
        >
          <i class='fas fa-plus'></i>
          {{localize 'DOCUMENT.New' type='clothing'}}
        </a>
      </div>
    </li>
    {{#each clothing as |item id|}}
      <li class="clothing item flexrow" data-item-id="{{item._id}}">
        <div class="clothing-name">
          <div class="clothing-image">
            <a class="rollable" data-roll-type="clothing"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></a>
          </div>
          <h4>{{item.name}}</h4>
        </div>
        <div class="clothing-type textcenter">{{localize item.system.type}}</div>
        <div class="clothing-protection textcenter">{{item.system.protection}}</div>
        <div class="clothing-insulation textcenter">{{item.system.insulation}}</div>
        <div class="clothing-load textcenter">{{item.system.load}}</div>
        <div class="clothing-stowage textcenter">{{localize item.system.stowage}}</div>
        <div class="clothing-controls">
          <a
            class='item-control item-edit'
            title='{{localize "DOCUMENT.Update" type='Clothing'}}'
            data-action='viewDoc'
          >
            <i class='fas fa-edit'></i>
          </a>
          <a
              class='item-control item-delete'
              title='{{localize "DOCUMENT.Delete" type='Clothing'}}'
              data-action='deleteDoc'
            >
              <i class='fas fa-trash'></i>
          </a>
        </div>
      </li>
    {{/each}}
  </ol>
</section>