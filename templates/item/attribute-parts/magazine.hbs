{{! Attributes Tab }}
<section
  class='tab attributes {{tab.cssClass}}'
  data-group='primary'
  data-tab='attributes'
>
  <div class="item-sheet-body">

    {{! === AMMUNITION === }}
    <div class="item-sheet-column">
      <label class="section-label">{{localize "RAILERS.Item.base.header.ammunition"}}</label>
      <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Item.Magazine.FIELDS.magType.label"}}</label>
        <select name="system.magType">
          {{selectOptions config.magTypes selected=system.magType localize=true}}
        </select>
      </div>
      <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Item.Magazine.FIELDS.ammoType"}}</label>
        <select name="system.ammoType">
          <option value="">{{localize "RAILERS.Item.Magazine.FIELDS.empty"}}</option>
          {{selectOptions config.ammoTypes selected=system.ammoType localize=true}}
        </select>
      </div>
      <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Item.Magazine.FIELDS.ammo.value"}}</label>
        <div class="resource-content flexrow flex-center flex-between">
          <input type="number" name="system.ammo.value" value="{{system.ammo.value}}" min="0"/>
          <span> / </span>
          <input type="number" name="system.ammo.max" value="{{system.ammo.max}}" min="0"/>
        </div>
      </div>
    </div>

    {{! === CARRY === }}
    <div class="item-sheet-column">
      <label class="section-label">{{localize "RAILERS.Item.base.header.carry"}}</label>
      <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Item.base.FIELDS.load"}}</label>
        <input type="number" name="system.load" value="{{system.load}}" data-dtype="Number"/>
      </div>
      <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Item.base.FIELDS.stowage.label"}}</label>
        <select name="system.stowage">
          {{selectOptions config.stowageOptions selected=system.stowage localize=true}}
        </select>
      </div>
    </div>

  </div>
</section>