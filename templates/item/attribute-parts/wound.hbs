{{! Wound - Attributes Tab }}
<section
  class='tab attributes {{tab.cssClass}}'
  data-group='primary'
  data-tab='attributes'
>
  <div class="item-sheet-body">
    <div class="item-sheet-column">
      <label class="section-label">{{localize "RAILERS.Item.base.header.stats"}}</label>
      <div class="item-sheet-group">
        <div class="resource">
            <label class="resource-label">{{localize "RAILERS.Item.Wound.FIELDS.damage"}}</label>
            <input type="number" name="system.damage" min="0" step="1" value="{{system.damage}}"/>
        </div>
        <div class="resource">
            <label class="resource-label">{{localize "RAILERS.Item.Wound.FIELDS.severity"}}</label>
            <input type="number" name="system.severity" min="0" step="1" value="{{system.severity}}"/>
        </div>
      </div>
    </div>
  </div>
</section>