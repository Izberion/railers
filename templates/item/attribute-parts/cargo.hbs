{{! Attributes Tab }}
<section
  class='tab attributes {{tab.cssClass}}'
  data-group='primary'
  data-tab='attributes'
>
    <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Price"}}</label>
        <input type="number" name="system.price" value="{{system.price}}" data-dtype="Number"/>
    </div>
    <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Weight"}}</label>
        <input type="number" name="system.weight" value="{{system.weight}}" data-dtype="Number"/>
    </div>
</section>