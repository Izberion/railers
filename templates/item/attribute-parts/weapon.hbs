{{! Attributes Tab }}
<section
  class='tab attributes {{tab.cssClass}}'
  data-group='primary'
  data-tab='attributes'
>
    <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Item.Weapon.FIELDS.damage"}}</label>
        <input type="number" name="system.damage" value="{{system.damage}}" data-dtype="Number"/>
    </div>
    <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Item.Weapon.FIELDS.severity"}}</label>
        <input type="number" name="system.severity" value="{{system.severity}}" data-dtype="Number"/>
    </div>
    <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Item.Weapon.FIELDS.attack"}}</label>
        <select name="system.attack">
            {{selectOptions config.actionTypeOptions selected=system.attack localize=true}}
        </select>
    </div>
        <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Item.Weapon.FIELDS.range.label"}}</label>
        <select name="system.range">
            {{selectOptions config.rangeOptions selected=system.range localize=true}}
        </select>
    </div>
    <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Item.Weapon.FIELDS.reload"}}</label>
        <select name="system.reload">
            {{selectOptions config.actionTypeOptions selected=system.reload localize=true}}
        </select>
    </div>
    <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Item.Weapon.FIELDS.magazine"}}</label>
        <input type="number" name="system.magazine.max" value="{{system.magazine.max}}" data-dtype="Number"/>
    </div>
    <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Item.Weapon.FIELDS.skill"}}</label>
        <select name="system.skill">
            {{selectOptions config.weaponSkillOptions selected=system.skill localize=true}}
        </select>
    </div>
    <div class="resource">
        <label class="resource-label">{{localize "RAILERS.Item.base.FIELDS.stowage.label"}}</label>
        <select name="system.stowage">
        {{selectOptions config.stowageOptions selected=system.stowage localize=true}}
        </select>
    </div>
</section>